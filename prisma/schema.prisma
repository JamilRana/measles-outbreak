generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  USER
  EDITOR
  ADMIN
  VIEWER
}

enum OutbreakStatus {
  DRAFT
  ACTIVE
  CONTAINED
  CLOSED
}

enum FieldType {
  NUMBER
  TEXT
  SELECT
  DATE
  BOOLEAN
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}


model Facility {
  id           String        @id @default(cuid())
  facilityCode String        @unique
  facilityName String
  facilityType String?
  division     String
  district     String
  upazila      String?
  phone        String?
  email        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  dailyReports DailyReport[]
  users        User[]

  @@index([division])
  @@index([district])
  @@index([facilityCode])
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String?
  name           String?
  nameNormalized String        @unique
  facilityId     String?
  managedDivisions String[]      @default([])
  managedDistricts String[]      @default([])
  role             Role          @default(USER)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  auditLogs      AuditLog[]
  dailyReports   DailyReport[]
  facility       Facility?     @relation(fields: [facilityId], references: [id])

  @@index([facilityId])
}

model Disease {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  outbreaks   Outbreak[]
}

model Outbreak {
  id         String         @id @default(cuid())
  diseaseId  String
  name       String
  status     OutbreakStatus @default(DRAFT)
  startDate  DateTime
  endDate    DateTime?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  reports    DailyReport[]
  formFields FormField[]
  disease    Disease        @relation(fields: [diseaseId], references: [id])

  @@index([diseaseId])
  @@index([status])
}

model FormField {
  id          String             @id @default(cuid())
  outbreakId  String
  label       String
  labelBn     String?
  fieldKey    String
  fieldType   FieldType          @default(NUMBER)
  options     String?
  section     String?
  isRequired  Boolean            @default(false)
  sortOrder   Int                @default(0)
  activeFrom  DateTime?
  activeTo    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  outbreak    Outbreak           @relation(fields: [outbreakId], references: [id])
  fieldValues ReportFieldValue[]

  @@unique([outbreakId, fieldKey])
  @@index([outbreakId])
}

model ReportFieldValue {
  id          String      @id @default(cuid())
  reportId    String
  formFieldId String
  value       String
  formField   FormField   @relation(fields: [formFieldId], references: [id])
  report      DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, formFieldId])
  @@index([reportId])
}

model DailyReport {
  id                String             @id @default(cuid())
  reportingDate     DateTime
  facilityId        String
  userId            String
  suspected24h      Int                @default(0)
  confirmed24h      Int                @default(0)
  suspectedDeath24h Int                @default(0)
  confirmedDeath24h Int                @default(0)
  admitted24h       Int                @default(0)
  discharged24h     Int                @default(0)
  serumSent24h      Int                @default(0)
  published         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isLocked          Boolean            @default(false)
  outbreakId        String
  facility          Facility           @relation(fields: [facilityId], references: [id])
  outbreak          Outbreak           @relation(fields: [outbreakId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  fieldValues       ReportFieldValue[]

  @@unique([facilityId, outbreakId, reportingDate])
  @@index([outbreakId])
  @@index([reportingDate])
  @@index([facilityId, reportingDate])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([entityType])
}

model EmailRecipient {
  id           String   @id @default(cuid())
  email        String   @unique
  designation  String
  organization String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  id      String    @id @default(cuid())
  email   String
  token   String    @unique
  expires DateTime
  type    TokenType

  @@unique([email, token])
}

model Settings {
  id                       String   @id @default(cuid())
  cutoffHour               Int      @default(14)
  cutoffMinute             Int      @default(0)
  editDeadlineHour         Int      @default(10)
  editDeadlineMinute       Int      @default(0)
  publishTimeHour          Int      @default(9)
  publishTimeMinute        Int      @default(0)
  enablePublicView         Boolean  @default(true)
  enableEmailNotifications Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  defaultOutbreakId        String?
}
