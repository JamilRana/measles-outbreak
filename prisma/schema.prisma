generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FacilityType {
  id         String     @id @default(cuid())
  name       String     @unique
  slug       String     @unique
  tier       String?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  facilities Facility[]
}

model Facility {
  id                String             @id @default(cuid())
  facilityCode      String             @unique
  facilityName      String
  facilityType      String?
  facilityTypeId    String?
  division          String
  district          String
  upazila           String?
  phone             String?
  email             String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  backlogSlots      BacklogSlot[]
  facilityTypeRel   FacilityType?      @relation(fields: [facilityTypeId], references: [id])
  reports           Report[]
  submissionWindows SubmissionWindow[]
  users             User[]

  @@index([division])
  @@index([district])
  @@index([facilityCode])
  @@index([facilityTypeId])
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  password         String?
  name             String?
  nameNormalized   String        @unique
  facilityId       String?
  managedDivisions String[]      @default([])
  managedDistricts String[]      @default([])
  role             Role          @default(USER)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  auditLogs        AuditLog[]
  reports          Report[]
  facility         Facility?     @relation(fields: [facilityId], references: [id])

  @@index([facilityId])
}

model Disease {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  outbreaks   Outbreak[]
}

model Outbreak {
  id                    String             @id @default(cuid())
  diseaseId             String
  name                  String
  status                OutbreakStatus     @default(DRAFT)
  startDate             DateTime
  endDate               DateTime?
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  allowBacklogReporting Boolean            @default(false)
  backlogStartDate      DateTime?
  backlogEndDate        DateTime?
  reportingFrequency    ReportingFrequency @default(DAILY)
  submissionOpenHour    Int                @default(0)
  submissionOpenMinute  Int                @default(0)
  cutoffHour            Int                @default(14)
  cutoffMinute          Int                @default(0)
  editDeadlineHour      Int                @default(10)
  editDeadlineMinute    Int                @default(0)
  publishTimeHour       Int                @default(9)
  publishTimeMinute     Int                @default(0)
  hasDashboard          Boolean            @default(true)
  targetDivisions       String[]           @default([])
  targetDistricts       String[]           @default([])
  targetFacilityTypeIds String[]           @default([])
  backlogSlots          BacklogSlot[]
  formFields            FormField[]
  disease               Disease            @relation(fields: [diseaseId], references: [id])
  reports               Report[]
  windows               SubmissionWindow[]

  @@index([diseaseId])
  @@index([status])
}

model FormField {
  id              String             @id @default(cuid())
  outbreakId      String
  label           String
  labelBn         String?
  fieldKey        String
  fieldType       FieldType          @default(NUMBER)
  options         String?
  section         String?
  isRequired      Boolean            @default(false)
  sortOrder       Int                @default(0)
  isCoreField     Boolean            @default(false)
  activeFrom      DateTime?
  activeTo        DateTime?
  validationRules Json?              @default("[]")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  outbreak        Outbreak           @relation(fields: [outbreakId], references: [id])
  fieldValues     ReportFieldValue[]

  @@unique([outbreakId, fieldKey])
  @@index([outbreakId])
}

model ReportFieldValue {
  id             String       @id @default(cuid())
  reportId       String
  formFieldId    String
  value          String
  formField      FormField    @relation(fields: [formFieldId], references: [id])
  report         Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, formFieldId])
  @@index([reportId])
}



model Report {
  id           String             @id @default(cuid())
  outbreakId   String
  facilityId   String
  userId       String
  periodStart  DateTime
  periodEnd    DateTime
  status       ReportStatus       @default(SUBMITTED)
  isLocked     Boolean            @default(false)
  lockedBy     String?
  lockedAt     DateTime?
  publishedAt  DateTime?
  dataSnapshot Json               @default("{}")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  facility     Facility           @relation(fields: [facilityId], references: [id])
  outbreak     Outbreak           @relation(fields: [outbreakId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  fieldValues  ReportFieldValue[]

  @@unique([facilityId, outbreakId, periodStart])
  @@index([outbreakId])
  @@index([periodStart])
  @@index([facilityId, periodStart])
  @@index([status])
  @@index([outbreakId, status, periodStart(sort: Desc)])
  @@index([facilityId, outbreakId, periodStart(sort: Desc)])
}

model SubmissionWindow {
  id                    String    @id @default(cuid())
  outbreakId            String
  facilityId            String?
  name                  String?
  periodStart           DateTime
  periodEnd             DateTime
  opensAt               DateTime
  closesAt              DateTime
  note                  String?
  createdBy             String?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  targetDivisions       String[]  @default([])
  targetDistricts       String[]  @default([])
  targetFacilityTypeIds String[]  @default([])
  facility              Facility? @relation(fields: [facilityId], references: [id])
  outbreak              Outbreak  @relation(fields: [outbreakId], references: [id])

  @@index([outbreakId])
  @@index([closesAt])
}

model BacklogSlot {
  id                    String    @id @default(cuid())
  outbreakId            String
  facilityId            String?
  periodStart           DateTime
  periodEnd             DateTime
  opensAt               DateTime
  closesAt              DateTime
  reason                String?
  createdBy             String?
  createdAt             DateTime  @default(now())
  targetDivisions       String[]  @default([])
  targetDistricts       String[]  @default([])
  targetFacilityTypeIds String[]  @default([])
  facility              Facility? @relation(fields: [facilityId], references: [id])
  outbreak              Outbreak  @relation(fields: [outbreakId], references: [id])

  @@index([outbreakId])
  @@index([facilityId])
  @@index([closesAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([entityType])
}

model EmailRecipient {
  id           String   @id @default(cuid())
  email        String   @unique
  designation  String
  organization String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  id      String    @id @default(cuid())
  email   String
  token   String    @unique
  expires DateTime
  type    TokenType

  @@unique([email, token])
}

model Settings {
  id                       String   @id @default(cuid())
  enablePublicView         Boolean  @default(true)
  enableEmailNotifications Boolean  @default(true)
  defaultOutbreakId        String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Indicator {
  id             String   @id @default(cuid())
  name           String
  description    String?
  numeratorKey   String
  denominatorKey String?
  multiplier     Float    @default(100)
  unit           String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum Role {
  USER
  EDITOR
  ADMIN
  VIEWER
}

enum OutbreakStatus {
  DRAFT
  ACTIVE
  CONTAINED
  CLOSED
}

enum FieldType {
  NUMBER
  TEXT
  SELECT
  DATE
  BOOLEAN
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ReportingFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  CUSTOM
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
  LOCKED
}
