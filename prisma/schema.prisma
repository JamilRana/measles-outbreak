generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  EDITOR
  ADMIN
  VIEWER
}

enum OutbreakStatus {
  DRAFT
  ACTIVE
  CONTAINED
  CLOSED
}

enum FieldType {
  NUMBER
  TEXT
  SELECT
  DATE
  BOOLEAN
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ReportingFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  CUSTOM
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
  LOCKED
}

// ─── Facility Type Lookup ────────────────────────────────────────────
model FacilityType {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  tier      String?  // e.g. "specialized", "district", "upazila", "other"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facilities Facility[]
}

// ─── Facility ────────────────────────────────────────────────────────
model Facility {
  id             String        @id @default(cuid())
  facilityCode   String        @unique
  facilityName   String
  facilityType   String?       // legacy string — kept for backward compat
  facilityTypeId String?       // FK to normalized FacilityType
  division       String
  district       String
  upazila        String?
  phone          String?
  email          String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  facilityTypeRel FacilityType? @relation(fields: [facilityTypeId], references: [id])
  dailyReports    DailyReport[]
  reports         Report[]
  users           User[]
  submissionWindows SubmissionWindow[]
  backlogSlots      BacklogSlot[]

  @@index([division])
  @@index([district])
  @@index([facilityCode])
  @@index([facilityTypeId])
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  password         String?
  name             String?
  nameNormalized   String        @unique
  facilityId       String?
  managedDivisions String[]      @default([])
  managedDistricts String[]      @default([])
  role             Role          @default(USER)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  auditLogs        AuditLog[]
  dailyReports     DailyReport[]
  reports          Report[]
  facility         Facility?     @relation(fields: [facilityId], references: [id])

  @@index([facilityId])
}

model Disease {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  outbreaks   Outbreak[]
}

model Outbreak {
  id         String         @id @default(cuid())
  diseaseId  String
  name       String
  status     OutbreakStatus @default(DRAFT)
  startDate  DateTime
  endDate    DateTime?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  
  allowBacklogReporting    Boolean  @default(false)
  backlogStartDate         DateTime?
  backlogEndDate           DateTime?

  reportingFrequency ReportingFrequency @default(DAILY)
  cutoffHour         Int               @default(14)
  cutoffMinute       Int               @default(0)
  editDeadlineHour   Int               @default(10)
  editDeadlineMinute Int               @default(0)
  publishTimeHour    Int               @default(9)
  publishTimeMinute  Int               @default(0)

  // Targeting: empty array = "all"
  targetDivisions       String[] @default([])
  targetDistricts       String[] @default([])
  targetFacilityTypeIds String[] @default([])

  dailyReports    DailyReport[]
  reports         Report[]
  formFields      FormField[]
  windows         SubmissionWindow[]
  backlogSlots    BacklogSlot[]
  disease         Disease        @relation(fields: [diseaseId], references: [id])

  @@index([diseaseId])
  @@index([status])
}


model FormField {
  id          String             @id @default(cuid())
  outbreakId  String
  label       String
  labelBn     String?
  fieldKey    String
  fieldType   FieldType          @default(NUMBER)
  options     String?
  section     String?
  isRequired  Boolean            @default(false)
  sortOrder   Int                @default(0)
  isCoreField Boolean            @default(false)
  activeFrom  DateTime?
  activeTo    DateTime?
  validationRules Json?          @default("[]")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  outbreak    Outbreak           @relation(fields: [outbreakId], references: [id])
  fieldValues ReportFieldValue[]

  @@unique([outbreakId, fieldKey])
  @@index([outbreakId])
}

model ReportFieldValue {
  id             String      @id @default(cuid())
  reportId       String?     // FK for legacy DailyReport (made optional)
  modernReportId String?     // FK for new Report model
  formFieldId    String
  value          String
  formField      FormField   @relation(fields: [formFieldId], references: [id])
  dailyReport    DailyReport? @relation(fields: [reportId], references: [id], onDelete: Cascade)
  report         Report?     @relation(fields: [modernReportId], references: [id], onDelete: Cascade)

  @@unique([reportId, formFieldId])
  @@unique([modernReportId, formFieldId])
  @@index([reportId])
  @@index([modernReportId])
}

model DailyReport {
  id                String             @id @default(cuid())
  reportingDate     DateTime
  facilityId        String
  userId            String
  suspected24h      Int                @default(0)
  confirmed24h      Int                @default(0)
  suspectedDeath24h Int                @default(0)
  confirmedDeath24h Int                @default(0)
  admitted24h       Int                @default(0)
  discharged24h     Int                @default(0)
  serumSent24h      Int                @default(0)
  published         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isLocked          Boolean            @default(false)
  outbreakId        String
  facility          Facility           @relation(fields: [facilityId], references: [id])
  outbreak          Outbreak           @relation(fields: [outbreakId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  fieldValues       ReportFieldValue[]

  @@unique([facilityId, outbreakId, reportingDate])
  @@index([outbreakId])
  @@index([reportingDate])
  @@index([facilityId, reportingDate])
}

model Report {
  id           String       @id @default(cuid())
  outbreakId   String
  facilityId   String
  userId       String
  periodStart  DateTime     // start of the period being reported
  periodEnd    DateTime     // end of the period (= periodStart for daily)
  status       ReportStatus @default(SUBMITTED)
  isLocked     Boolean      @default(false)
  lockedBy     String?
  lockedAt     DateTime?
  publishedAt  DateTime?
  dataSnapshot Json         @default("{}")  // JSONB cache
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  outbreak    Outbreak           @relation(fields: [outbreakId], references: [id])
  facility    Facility           @relation(fields: [facilityId], references: [id])
  user        User               @relation(fields: [userId], references: [id])
  fieldValues ReportFieldValue[]

  @@unique([facilityId, outbreakId, periodStart])
  @@index([outbreakId])
  @@index([periodStart])
  @@index([facilityId, periodStart])
  @@index([status])
}

// ─── Submission Window (with Targeting) ──────────────────────────────
model SubmissionWindow {
  id          String   @id @default(cuid())
  outbreakId  String
  facilityId  String?  // null = applies to all (or use targeting arrays)
  name        String?
  periodStart DateTime
  periodEnd   DateTime
  opensAt     DateTime
  closesAt    DateTime
  note        String?
  createdBy   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // ── Targeting: empty array = "all" ──
  targetDivisions     String[] @default([])
  targetDistricts     String[] @default([])
  targetFacilityTypeIds String[] @default([])

  outbreak Outbreak  @relation(fields: [outbreakId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([outbreakId])
  @@index([closesAt])
}

// ─── Backlog Slot (with Targeting) ───────────────────────────────────
model BacklogSlot {
  id          String    @id @default(cuid())
  outbreakId  String
  facilityId  String?   // null = all facilities
  periodStart DateTime
  periodEnd   DateTime
  opensAt     DateTime
  closesAt    DateTime
  reason      String?
  createdBy   String?
  createdAt   DateTime  @default(now())

  // ── Targeting: empty array = "all" ──
  targetDivisions     String[] @default([])
  targetDistricts     String[] @default([])
  targetFacilityTypeIds String[] @default([])

  outbreak Outbreak  @relation(fields: [outbreakId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([outbreakId])
  @@index([facilityId])
  @@index([closesAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([entityType])
}

model EmailRecipient {
  id           String   @id @default(cuid())
  email        String   @unique
  designation  String
  organization String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  id      String    @id @default(cuid())
  email   String
  token   String    @unique
  expires DateTime
  type    TokenType

  @@unique([email, token])
}

model Settings {
  id                       String   @id @default(cuid())
  enablePublicView         Boolean  @default(true)
  enableEmailNotifications Boolean  @default(true)
  defaultOutbreakId        String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Indicator {
  id          String   @id @default(cuid())
  name        String
  description String?
  numeratorKey String   
  denominatorKey String? 
  multiplier  Float    @default(100)
  unit        String?  // %, per 1000, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
