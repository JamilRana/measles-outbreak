// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String?
  facilityName    String
  nameNormalized  String    @unique
  facilityCode    String?
  facilityType    String?
  division        String?
  district        String?
  upazila         String?
  phone           String?
  emailVerified   DateTime?
  role            Role      @default(USER)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  dailyReports    DailyReport[]
  auditLogs       AuditLog[]

  @@index([division])
  @@index([district])
  @@index([facilityCode])
}

enum Role {
  USER
  MANAGER
  ADMIN
  VIEWER
}

model DailyReport {
  id                  String   @id @default(cuid())
  reportingDate       DateTime
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  
  // 24h data only - YTD calculated automatically
  suspected24h        Int      @default(0)
  confirmed24h        Int      @default(0)
  suspectedDeath24h   Int      @default(0)
  confirmedDeath24h   Int      @default(0)
  admitted24h         Int      @default(0)
  discharged24h       Int      @default(0)
  serumSent24h        Int      @default(0)
  
  published           Boolean  @default(false)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, reportingDate])
  @@index([reportingDate])
  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entityType])
}

model EmailRecipient {
  id           String   @id @default(cuid())
  email        String   @unique
  designation  String
  organization String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
  type    TokenType

  @@unique([email, token])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model Settings {
  id                        String   @id @default(cuid())
  cutoffHour                Int      @default(14)
  cutoffMinute              Int      @default(0)
  editDeadlineHour          Int      @default(10)
  editDeadlineMinute        Int      @default(0)
  publishTimeHour           Int      @default(9)
  publishTimeMinute         Int      @default(0)
  enablePublicView          Boolean  @default(true)
  enableEmailNotifications  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                DateTime @updatedAt
}
