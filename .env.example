# Database Connection
# Replace with your PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/measles_db?schema=public"

# NextAuth Configuration
# Run 'openssl rand -base64 32' to generate a secret
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Redis Configuration (Required for caching on redis_implemantation branch)
REDIS_URL="redis://localhost:6379"

# SMTP Configuration (For email notifications and SITREP reports)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="notifications@example.com"
SMTP_PASS="your-smtp-password"

# HRM SSO Configuration (Optional, for DGHS HRM integration)
HRM_API_TOKEN="your-hrm-api-token"

# Security Secrets
# Used for securing cron jobs via /api/admin/cron/...
CRON_SECRET="your-cron-secret-here"

# Public Branding & Contact
NEXT_PUBLIC_CONTROL_ROOM_CONTACT="MIS, DGHS (+8801XXXXXXX)"

# Environment
NODE_ENV="development"
